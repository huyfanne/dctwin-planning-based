eplus_env_config {
  weather_file: "data/weather/SGP_Singapore.486980_IWEC.epw"
  model_file: "models/idf/building.idf"
  simulation_time_config {
    begin_month: 9
    begin_day_of_month: 1
    end_month: 9
    end_day_of_month: 1
    number_of_timesteps_per_hour: 4
  }
  actions {
    control_type: PRE_SCHEDULED
    input_source: "data/schedule/workloads/ite_1.json"
    variable_name: "ite_1 cpu loading schedule"
    schedule_config {
      initial_value: 1.0
      lb: 0.0
      ub: 1.0
      schedule_type: ITE
      scheduled_ite_equipment_name: "ite_1"
    }
  }
  actions {
    control_type: AGENT_CONTROLLED
    variable_name: "chilled_water_loop_supply_temperature_setpoint"
    actuator_config {
      actuated_component_unique_name: "chilled water loop exit temperature setpoint schedule"
      actuated_component_type: Schedule_Constant
      actuated_component_control_type: Schedule_Value
    }
  }
  actions {
    control_type: AGENT_CONTROLLED
    variable_name: "acu_1_supply_air_temperature_setpoint"
    actuator_config {
      actuated_component_unique_name: "acu_1 air loop supply air temperature schedule"
      actuated_component_type: Schedule_Constant
      actuated_component_control_type: Schedule_Value
    }
  }
  actions {
    control_type: AGENT_CONTROLLED
    variable_name: "acu_1_supply_air_mass_flow_rate"
    actuator_config {
      actuated_component_unique_name: "acu_1 fan"
      actuated_component_type: Fan
      actuated_component_control_type: Fan_Air_Mass_Flow_Rate
    }
  }
  observations {
    exposed: false
    variable_name: "chilled water loop supply temperature"
    output_variable_config {
      key_value: "CHILLED WATER LOOP SUPPLY OUTLET NODE"
      variable_name: "System Node Temperature"
      reporting_frequency: "timestep"
    }
  }
  observations {
    exposed: false
    variable_name: "chilled water loop return temperature"
    output_variable_config {
      key_value: "CHILLED WATER LOOP SUPPLY INLET NODE"
      variable_name: "System Node Temperature"
      reporting_frequency: "timestep"
    }
  }
  observations {
