FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform {{ p_rgh }};

boundaryField
{

    
       "room_wall_.*"
    {
        type            zeroGradient;
    }

    "raised_floor_.*"
    {
         type            zeroGradient;
    }

    "opening_raised_floor_.*"
    {
        type           cyclic;
    }

    "false_ceiling_.*"
    {
        type            zeroGradient;
    }

    "opening_false_ceiling_.*"
    {
        type            cyclic;
    }

    "box_.*"
    {
        type            zeroGradient;
    }

    "rack_wall_.*"
    {
        type            zeroGradient;
    }

    "rack_panel_.*"
    {
        type            zeroGradient;
    }
    
    	"acu_supply_.*"
	{
	 type            zeroGradient;
	}
	
	"server_outlet_.*"
	{
	type            zeroGradient;
	}

	"acu_return_.*"
	{
	type            totalPressure;
	rho             rho;
	psi             none;
	gamma           1;
	p0              uniform 0;
	value           uniform 0;
	}
	
	"server_inlet_.*"
	{
	type            totalPressure;
	rho             rho;
	psi             none;
	gamma           1;
	p0              uniform 0;
	value           uniform 0;
	}

    "acu_wall_.*"
	{
	 type            zeroGradient;
	}

    "server_wall_.*"
	{
	 type            zeroGradient;
	}
}

