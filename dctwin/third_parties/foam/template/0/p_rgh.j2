FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform {{ p_rgh }};

boundaryField
{
    
    "room_wall_.*"
    {
        type            fixedFluxPressure;
        value           uniform $internalField;
    }

    "raised_floor_.*"
    {
        type            fixedFluxPressure;
        value           uniform $internalField;
    }

    "opening_raised_floor_.*"
    {
        type           cyclic;
    }

    "false_ceiling_.*"
    {
        type            fixedFluxPressure;
        value           uniform $internalField;
    }

    "opening_false_ceiling_.*"
    {
        type            cyclic;
    }

    "box_.*"
    {
        type            fixedFluxPressure;
        value           uniform $internalField;
    }

    "opening_box_.*"
    {
        type           cyclic;
    }

    "rack_wall_.*"
    {
        type            fixedFluxPressure;
        value           uniform $internalField;
    }

    "rack_cyclic_.*"
    {
        type           cyclic;
    }

    "rack_air_leak_.*"
    {
        type           porousBafflePressure;
        patchType      cyclic;
        D              100;
        I              50;
        length         0.15;
        uniformJump    false;
        jump           uniform 0;
        value          uniform 0;
    }

    "acu_wall_.*"
	{
        type            fixedFluxPressure;
        value           uniform $internalField;
	}
    
    "acu_supply_.*"
	{
        type            fixedFluxPressure;
        value           uniform $internalField;
	}

	"acu_return_.*"
	{
        type            totalPressure;
        rho             rho;
        psi             none;
        gamma           1;
        p0              uniform 0;
        value           uniform 0;
	}

    "heat_emitting_box_wall_.*"
	{
        type            fixedFluxPressure;
        value           uniform $internalField;
	}

    "heat_emitting_box_supply_.*"
	{
        type            fixedFluxPressure;
        value           uniform $internalField;
	}

    "heat_emitting_box_return_.*"
	{
        type            fixedFluxPressure;
        value           uniform $internalField;
	}

	"server_outlet_.*"
	{
        type            fixedFluxPressure;
        value           uniform $internalField;
	}
	
	"server_inlet_.*"
	{
        type            totalPressure;
        rho             rho;
        psi             none;
        gamma           1;
        p0              uniform 0;
        value           uniform 0;
	}

}

// ************************************************************************* //
